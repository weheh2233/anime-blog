---
import { Image } from 'astro:assets';
import { getImageByPath } from '../lib/imageMap';

export interface Props {
  title: string;
  description: string;
  slug: string;
  zone?: string;
  tags?: string[];
  publishDate?: Date;
  heroImage?: string;
  loading?: 'lazy' | 'eager';
}

const { title, description, slug, zone, tags = [], publishDate, heroImage, loading = 'lazy' } = Astro.props;
const formattedDate = publishDate
  ? publishDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })
  : '';
const resolvedImage = heroImage ? getImageByPath(heroImage) : null;
---

<article
  class="card-3d group cursor-pointer overflow-hidden transition-all duration-150"
  style={{
    background: 'var(--blog-surface)',
    border: '1px solid var(--blog-border)',
    borderRadius: 'var(--blog-radius-xl)',
    boxShadow: 'var(--blog-shadow)',
    minHeight: '360px'
  }}
>
  <a href={`/blog/${slug}`} class="block no-underline">
    <!-- 缩略图 16:9 -->
    <div class="relative overflow-hidden" style="aspect-ratio: 16/9; background: var(--blog-accent-lighter);">
      {resolvedImage ? (
        <Image 
          src={resolvedImage} 
          alt={title} 
          width={800} 
          height={450} 
          loading={loading}
          layout="responsive"
          class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-110"
        />
      ) : (
        <div class="w-full h-full flex items-center justify-center" style="color: var(--blog-text-tertiary);">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.3">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21 15 16 10 5 21"/>
          </svg>
        </div>
      )}

      <!-- 悬停光泽扫过 -->
      <div class="shine-sweep" aria-hidden="true"></div>
      <!-- Mini 3D 螺旋（右下角） -->
      <div class="mini-spiral" aria-hidden="true">
        <div class="mini-spiral-core">
          {Array.from({ length: 10 }, (_, i) => (
            <div class="mini-strip" style={{ '--i': i, '--total': 10 }} />
          ))}
        </div>
      </div>
    </div>

    <!-- 内容层固定最小高度，防止文字长短导致卡片高度跳动 -->
    <div class="p-4 relative" style="min-height: 140px;">
      <!-- 专区 + 日期 -->
      <div class="flex items-center gap-2 mb-2">
        {zone && (
          <span class="text-xs px-2 py-0.5 rounded-[var(--blog-radius-sm)]" style="background: var(--blog-accent-light); color: var(--blog-accent);">
            {zone}
          </span>
        )}
        {formattedDate && (
          <time class="text-xs" style="color: var(--blog-text-tertiary);">{formattedDate}</time>
        )}
      </div>

      <!-- 标题 -->
      <h3 class="font-bold text-base mb-1 line-clamp-2 transition-colors duration-300 group-hover:text-[var(--blog-accent)]" style="color: var(--blog-text-primary);">
        {title}
      </h3>

      <!-- 描述 -->
      <p class="text-sm line-clamp-2 mb-3" style="color: var(--blog-text-secondary);">
        {description}
      </p>

      <!-- 标签 -->
      {tags.length > 0 && (
        <div class="flex gap-1.5 flex-wrap">
          {tags.slice(0, 3).map((tag) => (
            <span class="text-xs px-1.5 py-0.5 rounded-[var(--blog-radius-sm)]" style="background: var(--blog-accent-lighter); color: var(--blog-text-tertiary);">
              #{tag}
            </span>
          ))}
        </div>
      )}
    </div>
  </a>
</article>

<style>
  /* ===== 3D 倾斜容器（完整保留倾斜动画，仅修复过渡冲突） ===== */
  .card-3d {
    transform-style: preserve-3d;
    /* transition-all 统一缓动，消除JS/CSS双重过渡打架 */
    transition: all 0.15s ease-out;
  }

  .card-3d:hover {
    box-shadow:
      0 0 0 2px var(--blog-accent),
      0 0 30px rgba(59, 74, 107, 0.25),
      0 12px 40px rgba(0, 0, 0, 0.12) !important;
  }

  :root.dark .card-3d:hover {
    box-shadow:
      0 0 0 2px var(--blog-accent),
      0 0 40px rgba(90, 122, 158, 0.35),
      0 12px 40px rgba(0, 0, 0, 0.35) !important;
  }

  /* ===== 光泽扫过 ===== */
  .shine-sweep {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.35s ease;
    background: linear-gradient(
      105deg,
      transparent 35%,
      rgba(255, 255, 255, 0.12) 45%,
      rgba(255, 255, 255, 0.25) 50%,
      rgba(255, 255, 255, 0.12) 55%,
      transparent 65%
    );
  }

  .card-3d:hover .shine-sweep {
    opacity: 1;
    animation: shineSweep 0.85s ease-out forwards;
  }

  @keyframes shineSweep {
    0%   { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }

  /* ===== Mini 3D Spiral ===== */
  .mini-spiral {
    position: absolute;
    right: 10px;
    bottom: 10px;
    width: 40px;
    height: 40px;
    perspective: 180px;
    opacity: 0;
    transform: scale(0.6);
    transition: opacity 0.4s ease, transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    pointer-events: none;
    z-index: 3;
  }

  .card-3d:hover .mini-spiral {
    opacity: 0.55;
    transform: scale(1);
    animation: miniFloat 1.4s linear infinite;
  }

  .mini-spiral-core {
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
  }

  .mini-strip {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 5px;
    height: 22px;
    margin: -11px -2.5px;
    border-radius: 2px;
    background: var(--blog-accent);
    transform: rotateY(calc(var(--i) * 360deg / var(--total))) translateZ(18px);
    opacity: 0.65;
  }

  .mini-strip:nth-child(even) {
    background: var(--blog-text-secondary);
    height: 16px;
    margin-top: -8px;
  }

  .mini-strip:nth-child(3n) {
    background: var(--blog-accent-hover);
    height: 28px;
    margin-top: -14px;
  }

  @keyframes miniFloat {
    0%   { transform: scale(1) rotateX(-25deg) rotateY(0deg); }
    100% { transform: scale(1) rotateX(-25deg) rotateY(360deg); }
  }

  /* ===== Reduced Motion 完整兼容（修复倾斜动画未禁用问题） ===== */
  @media (prefers-reduced-motion: reduce) {
    .card-3d {
      transform: none !important;
      transition: none !important;
    }
    .card-3d:hover { transform: none !important; }
    .mini-spiral { display: none; }
    .shine-sweep { display: none; }
  }
</style>

<script>
  // 3D 倾斜：跟踪鼠标位置（新增减弱动画判断，彻底规避多余渲染抖动）
  function init3DTilt() {
    // 检测系统减弱动画偏好，匹配css媒体查询
    const motionReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (motionReduced) return;

    document.querySelectorAll('.card-3d').forEach(card => {
      if (card.dataset.tiltBound) return;
      card.dataset.tiltBound = '1';

      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        const cx = rect.width / 2;
        const cy = rect.height / 2;
        const rx = ((y - cy) / cy) * -8;
        const ry = ((x - cx) / cx) * 8;
        card.style.transform =
          `perspective(800px) rotateX(${rx.toFixed(1)}deg) rotateY(${ry.toFixed(1)}deg) translateY(-4px)`;
      });

      card.addEventListener('mouseleave', () => {
        card.style.transform =
          'perspective(800px) rotateX(0deg) rotateY(0deg) translateY(0px)';
      });
    });
  }

  // 初始化 + Astro View Transitions 后重新绑定
  init3DTilt();
  document.addEventListener('astro:page-load', init3DTilt);
</script>
