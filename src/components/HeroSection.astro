---
interface Props {
  title?: string;
  subtitle?: string;
  showSpiral?: boolean;
  lines?: string[];
}

const {
  title,
  subtitle,
  showSpiral = true,
  lines = [
    '正在和世界解耦。',
    '说出去的话就像射出的飞矢，想收也收不回了。最好的方式还是沉默，唯有在无言中才能言尽一切，追溯到能指链条的起源之地，从而由你带领它走向终结。',
    '无尽的远方，无穷的人们，都与我有关。',
  ],
} = Astro.props;
import { gallery1, gallery2, gallery3, avatar, heroBanner } from '../lib/imageMap';
const totalCards = 16;

const cardImages = [
  gallery1.src,
  gallery2.src,
  gallery3.src,
  avatar.src,
  heroBanner.src,
];

const cardFilters = [
  '',
  'hue-rotate(15deg) saturate(1.1)',
  'hue-rotate(-12deg) saturate(1.15) brightness(1.05)',
  'hue-rotate(25deg) saturate(0.95) brightness(1.08)',
  'hue-rotate(-20deg) saturate(1.2)',
  'hue-rotate(8deg) saturate(1.05) brightness(0.95)',
  'hue-rotate(-8deg) saturate(1.12) brightness(1.02)',
  'hue-rotate(18deg) saturate(0.9) brightness(1.1)',
];
---

<section class="relative min-h-[65vh] flex items-center overflow-hidden">
  {showSpiral && (
    <div class="acrylic-carousel hidden md:block" aria-hidden="true">
      <div class="carousel-core">
        {
          Array.from({ length: totalCards }, (_, i) => (
            <div class="acrylic-card" style={{ '--i': i, '--total': totalCards }}>
              <div class="acrylic-inner">
                <div class="acrylic-image" style={`background-image: url(${cardImages[i % cardImages.length]}); background-size: cover; background-position: center; filter: ${cardFilters[i % cardFilters.length]};`} />
                <div class="acrylic-shine" />
              </div>
              <div class="acrylic-edge" />
            </div>
          ))
        }
      </div>
    </div>
  )}

  <div class="mx-auto px-4 md:px-8 py-24 w-full relative z-10" style="max-width: 1500px;">
    <div class="max-w-2xl">
      <h1 class="scroll-reveal text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight" style="color: var(--blog-text-primary);">
        {title && <span style="color: var(--blog-accent);">✦</span>}
        {' '}
        {title || '代码与纸飞机'}
        <br />
        <span class="bg-linear-to-r from-[var(--blog-accent)] to-[var(--blog-text-secondary)] dark:from-[var(--blog-accent)] dark:to-[var(--blog-text-tertiary)] bg-clip-text text-transparent">
          {subtitle || '记录技术 · 分享生活'}
        </span>
      </h1>
      <p class="scroll-reveal text-lg md:text-xl mb-8 leading-relaxed" style="color: var(--blog-text-secondary);" data-delay="1">
        {Astro.slots.has('default') ? <slot /> : '一个喜欢动漫的开发者博客'}
      </p>
      <div class="hero-card">
        <p class="hero-type-line" data-hero-lines={JSON.stringify(lines)}></p>
      </div>
    </div>
  </div>
</section>

<style>
  .acrylic-carousel {
    position: absolute;
    right: -60px;
    top: 50%;
    transform: translateY(-50%);
    width: 520px;
    height: 520px;
    perspective: 1200px;
    pointer-events: none;
    z-index: 0;
  }

  .carousel-core {
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    animation: spin 16s linear infinite;
  }

  .acrylic-card {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 80px;
    height: 112px;
    margin: -56px -40px;
    transform-style: preserve-3d;
    transform: rotateY(calc(var(--i) * 360deg / var(--total))) translateZ(200px);
  }

  .acrylic-card:nth-child(odd) {
    width: 64px;
    height: 88px;
    margin: -44px -32px;
    transform: rotateY(calc(var(--i) * 360deg / var(--total))) translateZ(120px);
  }

  .acrylic-inner {
    width: 100%;
    height: 100%;
    border-radius: 14px;
    overflow: hidden;
    position: relative;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1.5px solid rgba(255, 255, 255, 0.4);
    box-shadow:
      0 4px 20px rgba(0, 0, 0, 0.06),
      inset 0 0 0 1px rgba(255, 255, 255, 0.2);
  }

  :root.dark .acrylic-inner {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.12);
  }

  .acrylic-image {
    width: 100%;
    height: 100%;
    position: relative;
    z-index: 0;
  }

  .acrylic-shine {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.3) 0%,
      transparent 40%,
      transparent 60%,
      rgba(255, 255, 255, 0.05) 100%
    );
    pointer-events: none;
  }

  .acrylic-edge {
    position: absolute;
    bottom: -6px;
    left: 4px;
    right: 4px;
    height: 6px;
    border-radius: 0 0 10px 10px;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-top: none;
    transform: translateZ(-2px);
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.04);
  }

  :root.dark .acrylic-edge {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(255, 255, 255, 0.08);
  }

  @keyframes spin {
    from { transform: rotateX(-8deg) rotateY(0deg); }
    to   { transform: rotateX(-8deg) rotateY(360deg); }
  }

  .scroll-reveal {
    opacity: 0;
    transform: translateY(30px);
    animation: heroReveal 0.8s ease-out forwards;
  }

  .scroll-reveal[data-delay="1"] {
    animation-delay: 0.2s;
  }

  @keyframes heroReveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-card {
    max-width: 36rem;
    padding: 1.25rem 1.75rem;
    border-radius: var(--blog-radius-lg);
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.55);
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.03);
  }

  :root.dark .hero-card {
    background: rgba(26, 29, 39, 0.5);
    border-color: rgba(255, 255, 255, 0.07);
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.18);
  }

  .hero-type-line {
    margin: 0;
    color: var(--blog-text-primary);
    font-size: clamp(1rem, 1.2vw, 1.2rem);
    font-weight: 600;
    line-height: 1.7;
    transition: opacity 0.24s ease;
  }

  .hero-type-line.is-typing::after {
    content: '|';
    display: inline-block;
    margin-left: 0.12em;
    color: var(--blog-accent);
    animation: caretBlink 0.72s step-end infinite;
  }

  @keyframes caretBlink {
    50% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .acrylic-carousel { display: none; }
    .scroll-reveal {
      opacity: 1;
      transform: none;
      animation: none;
    }
    .hero-type-line::after { display: none; }
  }
</style>

<script>
  function runHeroLineTyping() {
    const line = document.querySelector<HTMLElement>('.hero-type-line[data-hero-lines]');
    if (!line || line.dataset.typed === 'true') return;

    let texts = [''];
    try {
      texts = JSON.parse(line.dataset.heroLines || '[""]');
    } catch (_) {
      texts = [''];
    }

    const candidates = texts.filter((text) => text.trim().length > 0);
    const text = candidates[Math.floor(Math.random() * candidates.length)] || '';
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    line.dataset.typed = 'true';

    if (reduceMotion) {
      line.textContent = text;
      return;
    }

    line.textContent = '';
    line.classList.add('is-typing');

    let index = 0;
    const typeNext = () => {
      line.textContent = text.slice(0, index);
      if (index >= text.length) {
        line.classList.remove('is-typing');
        return;
      }
      index += 1;
      window.setTimeout(typeNext, text.length > 40 ? 42 : 82);
    };

    window.setTimeout(typeNext, 220);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', runHeroLineTyping, { once: true });
  } else {
    runHeroLineTyping();
  }

  document.addEventListener('astro:page-load', runHeroLineTyping);
</script>
