---
interface Props {
  title?: string;
}

const { title = "Qianqiu's Blog" } = Astro.props;
---

<section class="home-intro">
  <h1 data-text={title}>{title}</h1>
</section>

<style>
  .home-intro {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 90vh;
    padding: 2rem;
  }

  .home-intro h1 {
    margin: 0;
    font-family: var(--blog-font-sans);
    font-size: clamp(4rem, 13vw, 11rem);
    font-weight: 900;
    line-height: 0.88;
    letter-spacing: -0.04em;
    text-align: center;
    color: var(--blog-text-primary);
    text-shadow:
      0 0 50px rgba(139, 156, 255, 0.7),
      0 0 100px rgba(139, 156, 255, 0.4),
      0 0 180px rgba(139, 156, 255, 0.2),
      0 0 300px rgba(180, 150, 255, 0.12),
      0 0 400px rgba(180, 150, 255, 0.06);
    animation: glowPulse 3s ease-in-out infinite alternate;
  }

  :root.dark .home-intro h1 {
    text-shadow:
      0 0 50px rgba(139, 156, 255, 0.85),
      0 0 100px rgba(139, 156, 255, 0.55),
      0 0 180px rgba(139, 156, 255, 0.3),
      0 0 300px rgba(180, 150, 255, 0.18),
      0 0 400px rgba(180, 150, 255, 0.08);
  }

  @keyframes glowPulse {
    0% {
      text-shadow:
        0 0 50px rgba(139, 156, 255, 0.7),
        0 0 100px rgba(139, 156, 255, 0.4),
        0 0 180px rgba(139, 156, 255, 0.2),
        0 0 300px rgba(180, 150, 255, 0.12),
        0 0 400px rgba(180, 150, 255, 0.06);
    }
    100% {
      text-shadow:
        0 0 75px rgba(139, 156, 255, 0.85),
        0 0 130px rgba(139, 156, 255, 0.52),
        0 0 210px rgba(139, 156, 255, 0.28),
        0 0 340px rgba(180, 150, 255, 0.17),
        0 0 450px rgba(180, 150, 255, 0.09);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-intro h1 {
      animation: none;
    }
  }
</style>
