---
import '../styles/pomodoro-tokens.css';
import '../styles/flip-digit.css';
import '../styles/pomodoro-widget.css';
import PomodoroSidebarTimer from './PomodoroSidebarTimer';
---

<div class="pomodoro-sidebar-card" data-pagefind-ignore>
  <div class="pomodoro-sidebar-card__glass" aria-hidden="true">
    <span></span>
    <span></span>
    <span></span>
  </div>
  <PomodoroSidebarTimer client:load />
</div>

<style>
  .pomodoro-sidebar-card {
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(160deg, var(--pomodoro-rain-glass-fill-strong), var(--pomodoro-rain-glass-fill)),
      url('/pomodoro-bg/bg.png') center / cover no-repeat;
    border: 1px solid var(--pomodoro-rain-glass-border);
    border-radius: var(--blog-radius-lg);
    box-shadow: var(--blog-shadow-md), inset 0 1px 0 var(--pomodoro-rain-glass-rim);
    transition: transform 160ms ease, box-shadow 160ms ease, border-color 160ms ease;
  }

  .pomodoro-sidebar-card:hover {
    border-color: var(--blog-accent);
    box-shadow: var(--blog-shadow-hover);
  }

  .pomodoro-sidebar-card:focus-visible {
    outline: 3px solid var(--pomodoro-focus-ring);
    outline-offset: 3px;
  }

  .pomodoro-sidebar-card__glass {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .pomodoro-sidebar-card__glass::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 16% 20%, var(--pomodoro-rain-drop-static) 0 1.2px, transparent 2.4px),
      radial-gradient(circle at 72% 34%, var(--pomodoro-rain-drop-static) 0 1px, transparent 2px),
      radial-gradient(circle at 86% 74%, var(--pomodoro-rain-drop-static) 0 1.3px, transparent 2.5px);
    opacity: 0.55;
  }

  .pomodoro-sidebar-card__glass span {
    position: absolute;
    border-radius: 999px;
    background: var(--pomodoro-rain-glass-sheen);
    filter: blur(10px);
  }

  .pomodoro-sidebar-card__glass span:nth-child(1) {
    width: 120px;
    height: 28px;
    top: 14px;
    right: -32px;
    transform: rotate(-18deg);
  }

  .pomodoro-sidebar-card__glass span:nth-child(2) {
    width: 70px;
    height: 70px;
    right: 16px;
    bottom: -34px;
    opacity: 0.42;
  }

  .pomodoro-sidebar-card__glass span:nth-child(3) {
    width: 42px;
    height: 42px;
    left: -14px;
    bottom: 30px;
    opacity: 0.32;
  }

  .pomodoro-sidebar-card > :not(.pomodoro-sidebar-card__glass) {
    position: relative;
    z-index: 1;
  }
</style>
