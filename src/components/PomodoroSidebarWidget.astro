---
import '../styles/pomodoro-tokens.css';
---

<a class="pomodoro-sidebar-card" href="/pomodoro" aria-label="打开番茄钟完整页面" data-pagefind-ignore>
  <div class="pomodoro-sidebar-card__glass" aria-hidden="true">
    <span></span>
    <span></span>
    <span></span>
  </div>
  <div>
    <span class="pomodoro-sidebar-card__eyebrow">Focus timer</span>
    <h3>番茄钟</h3>
    <p>25 分钟专注，休息时自动切换。点击进入完整面板。</p>
  </div>
  <span class="pomodoro-sidebar-card__cta">开始专注</span>
</a>

<style>
  .pomodoro-sidebar-card {
    position: relative;
    display: grid;
    gap: 14px;
    overflow: hidden;
    padding: 18px;
    color: var(--blog-text-primary);
    background:
      linear-gradient(160deg, var(--pomodoro-rain-glass-fill-strong), var(--pomodoro-rain-glass-fill)),
      url('/pomodoro-bg/bg.png') center / cover no-repeat;
    border: 1px solid var(--pomodoro-rain-glass-border);
    border-radius: var(--blog-radius-lg);
    box-shadow: var(--blog-shadow-md), inset 0 1px 0 var(--pomodoro-rain-glass-rim);
    text-decoration: none;
    transition: transform 160ms ease, box-shadow 160ms ease, border-color 160ms ease;
  }

  .pomodoro-sidebar-card:hover {
    color: var(--blog-text-primary);
    transform: translateY(-2px);
    border-color: var(--blog-accent);
    box-shadow: var(--blog-shadow-hover);
  }

  .pomodoro-sidebar-card:focus-visible {
    outline: 3px solid var(--pomodoro-focus-ring);
    outline-offset: 3px;
  }

  .pomodoro-sidebar-card__glass {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .pomodoro-sidebar-card__glass::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 16% 20%, var(--pomodoro-rain-drop-static) 0 1.2px, transparent 2.4px),
      radial-gradient(circle at 72% 34%, var(--pomodoro-rain-drop-static) 0 1px, transparent 2px),
      radial-gradient(circle at 86% 74%, var(--pomodoro-rain-drop-static) 0 1.3px, transparent 2.5px);
    opacity: 0.55;
  }

  .pomodoro-sidebar-card__glass span {
    position: absolute;
    border-radius: 999px;
    background: var(--pomodoro-rain-glass-sheen);
    filter: blur(10px);
  }

  .pomodoro-sidebar-card__glass span:nth-child(1) {
    width: 120px;
    height: 28px;
    top: 14px;
    right: -32px;
    transform: rotate(-18deg);
  }

  .pomodoro-sidebar-card__glass span:nth-child(2) {
    width: 70px;
    height: 70px;
    right: 16px;
    bottom: -34px;
    opacity: 0.42;
  }

  .pomodoro-sidebar-card__glass span:nth-child(3) {
    width: 42px;
    height: 42px;
    left: -14px;
    bottom: 30px;
    opacity: 0.32;
  }

  .pomodoro-sidebar-card > :not(.pomodoro-sidebar-card__glass) {
    position: relative;
    z-index: 1;
  }

  .pomodoro-sidebar-card__eyebrow {
    display: block;
    margin-bottom: 8px;
    color: var(--blog-text-tertiary);
    font-family: var(--blog-font-mono);
    font-size: 0.7rem;
    line-height: 1.4;
    text-transform: uppercase;
  }

  .pomodoro-sidebar-card h3 {
    margin: 0 0 8px;
    color: var(--blog-text-primary);
    font-size: 1rem;
    line-height: 1.35;
  }

  .pomodoro-sidebar-card p {
    margin: 0;
    color: var(--blog-text-secondary);
    font-size: 0.78rem;
    line-height: 1.7;
  }

  .pomodoro-sidebar-card__cta {
    width: fit-content;
    padding: 7px 11px;
    color: var(--blog-surface);
    background: var(--blog-accent);
    border-radius: var(--blog-radius-sm);
    font-size: 0.78rem;
    line-height: 1.2;
  }
</style>
