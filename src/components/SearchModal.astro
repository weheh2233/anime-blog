<div id="search-modal" class="search-modal" aria-hidden="true" role="dialog" aria-label="搜索">
  <div class="search-backdrop" id="search-backdrop"></div>
  <div class="search-panel">
    <!-- 搜索输入 -->
    <div class="search-input-wrap">
      <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input
        id="search-input"
        type="text"
        class="search-input"
        placeholder="搜索文章..."
        autocomplete="off"
      />
      <kbd class="search-kbd">ESC</kbd>
    </div>

    <!-- 搜索结果 -->
    <div class="search-results" id="search-results">
      <div class="search-empty">
        <span class="search-empty-icon">⌘</span>
        <p>输入关键词搜索文章</p>
      </div>
    </div>

    <!-- 底部信息 -->
    <div class="search-footer" id="search-footer">
      <span>↑↓ 导航 &nbsp; ↵ 打开 &nbsp; esc 关闭</span>
      <span>Pagefind</span>
    </div>
  </div>
</div>

<style is:global>
  .search-modal {
    position: fixed; inset: 0; z-index: 99998;
    display: flex; align-items: flex-start; justify-content: center;
    padding-top: 16vh;
    opacity: 0; pointer-events: none;
    transition: opacity 0.2s ease;
  }
  .search-modal.open { opacity: 1; pointer-events: auto; }

  .search-backdrop {
    position: absolute; inset: 0;
    background: rgba(0, 0, 0, 0.5);
  }

  .search-panel {
    position: relative;
    width: 90vw; max-width: 560px;
    max-height: 70vh;
    display: flex; flex-direction: column;
    border-radius: var(--blog-radius-xl);
    background: var(--blog-surface);
    border: 1px solid var(--blog-border);
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.18);
    overflow: hidden;
  }

  /* 输入区 */
  .search-input-wrap {
    display: flex; align-items: center; gap: 8px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--blog-border-light);
  }
  .search-icon {
    color: var(--blog-text-tertiary); flex-shrink: 0;
  }
  .search-input {
    flex: 1; border: none; outline: none;
    font-size: 1rem;
    background: transparent;
    color: var(--blog-text-primary);
    font-family: var(--blog-font-sans);
  }
  .search-input::placeholder { color: var(--blog-text-tertiary); }
  .search-kbd {
    display: inline-block;
    padding: 2px 8px;
    font-size: 11px; font-family: var(--blog-font-mono);
    border-radius: 4px;
    background: var(--blog-accent-lighter);
    color: var(--blog-text-tertiary);
    border: 1px solid var(--blog-border-light);
  }

  /* 结果区 */
  .search-results {
    flex: 1; overflow-y: auto; padding: 8px;
    min-height: 120px;
  }
  .search-empty {
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    padding: 40px 20px;
    color: var(--blog-text-tertiary);
  }
  .search-empty-icon { font-size: 2rem; margin-bottom: 8px; opacity: 0.4; }

  .search-result-item {
    display: block;
    padding: 12px 14px;
    border-radius: var(--blog-radius-md);
    text-decoration: none;
    transition: background 0.15s ease;
    cursor: pointer;
  }
  .search-result-item:hover,
  .search-result-item.active {
    background: var(--blog-accent-lighter);
  }

  .search-result-title {
    font-size: 0.95rem; font-weight: 700;
    color: var(--blog-text-primary);
    margin-bottom: 4px;
  }
  .search-result-title mark {
    background: rgba(59, 74, 107, 0.15);
    color: var(--blog-accent);
    border-radius: 2px;
    padding: 0 1px;
  }
  .search-result-excerpt {
    font-size: 0.8rem;
    color: var(--blog-text-secondary);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .search-result-excerpt mark {
    background: rgba(59, 74, 107, 0.12);
    color: var(--blog-text-primary);
    border-radius: 2px;
    padding: 0 1px;
  }
  .search-result-zone {
    display: inline-block;
    font-size: 0.7rem;
    padding: 1px 8px;
    border-radius: var(--blog-radius-sm);
    background: var(--blog-accent-light);
    color: var(--blog-accent);
    margin-top: 6px;
  }
  .search-results-loading {
    display: flex; align-items: center; justify-content: center;
    padding: 30px;
    color: var(--blog-text-tertiary);
    font-size: 0.85rem;
  }

  /* 底部 */
  .search-footer {
    display: flex; justify-content: space-between;
    padding: 8px 16px;
    font-size: 0.7rem;
    color: var(--blog-text-tertiary);
    border-top: 1px solid var(--blog-border-light);
  }
</style>

<script>
  (function() {
    const modal = document.getElementById('search-modal');
    const input = document.getElementById('search-input');
    const results = document.getElementById('search-results');
    const footer = document.getElementById('search-footer');
    const backdrop = document.getElementById('search-backdrop');
    if (!modal || !input || !results) return;

    let pagefindReady = false;
    let activeIdx = -1;
    let resultItems: HTMLElement[] = [];
    let debounceTimer: ReturnType<typeof setTimeout>;

    // 加载 Pagefind（通过 script 标签避免 Vite 打包分析）
    function loadPagefind(): Promise<any> {
      return new Promise((resolve, reject) => {
        // 检查是否已加载
        if ((window as any).pagefind) {
          resolve((window as any).pagefind);
          return;
        }
        const script = document.createElement('script');
        script.src = '/pagefind/pagefind.js';
        script.onload = () => {
          const pf = (window as any).pagefind;
          if (pf) {
            pf.options?.({ basePath: '/pagefind/' });
            pagefindReady = true;
            resolve(pf);
          } else {
            reject(new Error('Pagefind failed to init'));
          }
        };
        script.onerror = () => reject(new Error('Pagefind not available'));
        document.head.appendChild(script);
      });
    }

    let pagefindP = new Promise<any>((resolve) => {
      // dev 模式下 Pagefind 索引不存在，直接跳过
      fetch('/pagefind/pagefind.js', { method: 'HEAD', signal: AbortSignal.timeout(2000) })
        .then(r => { if (r.ok) resolve(loadPagefind()); else resolve(null); })
        .catch(() => resolve(null));
    });

    function open() {
      modal.classList.add('open');
      modal.setAttribute('aria-hidden', 'false');
      input.focus();
      if (input.value) doSearch(input.value);
    }

    function close() {
      modal.classList.remove('open');
      modal.setAttribute('aria-hidden', 'true');
      input.value = '';
      results.innerHTML = '<div class="search-empty"><span class="search-empty-icon">⌘</span><p>输入关键词搜索文章</p></div>';
      activeIdx = -1;
      resultItems = [];
    }

    async function doSearch(term: string) {
      if (!term.trim()) {
        results.innerHTML = '<div class="search-empty"><span class="search-empty-icon">⌘</span><p>输入关键词搜索文章</p></div>';
        resultItems = [];
        activeIdx = -1;
        return;
      }

      results.innerHTML = '<div class="search-results-loading">搜索中...</div>';

      const pagefind = await pagefindP;
      if (!pagefind) {
        results.innerHTML = '<div class="search-empty"><p>搜索不可用</p></div>';
        return;
      }

      try {
        const search = await pagefind.search(term, { excerptLength: 20 });
        if (!search?.results?.length) {
          results.innerHTML = '<div class="search-empty"><p>没有找到 「<b>' + term + '</b>」 相关的结果</p></div>';
          resultItems = [];
          activeIdx = -1;
          return;
        }

        const htmlParts: string[] = [];
        resultItems = [];

        for (let i = 0; i < Math.min(search.results.length, 10); i++) {
          const r = search.results[i];
          const data = await r.data();

          // 从 meta 中获取 zone
          const zone = data.meta?.zone || '';

          htmlParts.push(`
            <a class="search-result-item" data-idx="${i}" href="${data.url}">
              <div class="search-result-title">${data.meta?.title || r.id}</div>
              <div class="search-result-excerpt">${data.excerpt || ''}</div>
              ${zone ? '<span class="search-result-zone">' + zone + '</span>' : ''}
            </a>
          `);
        }

        results.innerHTML = htmlParts.join('');
        resultItems = Array.from(results.querySelectorAll('.search-result-item'));
        activeIdx = -1;

        // 绑定点击
        resultItems.forEach((item, idx) => {
          item.addEventListener('mouseenter', () => setActive(idx));
        });
      } catch {
        results.innerHTML = '<div class="search-empty"><p>搜索出错，请重试</p></div>';
      }
    }

    function setActive(idx: number) {
      resultItems.forEach(item => item.classList.remove('active'));
      activeIdx = idx;
      if (idx >= 0 && idx < resultItems.length) {
        resultItems[idx].classList.add('active');
        resultItems[idx].scrollIntoView({ block: 'nearest' });
      }
    }

    // 事件绑定
    input.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => doSearch(input.value), 200);
    });

    input.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        setActive(Math.min(activeIdx + 1, resultItems.length - 1));
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        setActive(Math.max(activeIdx - 1, 0));
      } else if (e.key === 'Enter') {
        e.preventDefault();
        if (activeIdx >= 0 && resultItems[activeIdx]) {
          (resultItems[activeIdx] as HTMLAnchorElement).click();
        }
      } else if (e.key === 'Escape') {
        close();
      }
    });

    backdrop.addEventListener('click', close);

    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
        e.preventDefault();
        if (modal.classList.contains('open')) close();
        else open();
      }
    });

    // 暴露给 Header 的搜索按钮
    window.__toggleSearch = () => {
      if (modal.classList.contains('open')) close();
      else open();
    };

    // Astro View Transitions 后恢复
    document.addEventListener('astro:page-load', () => {
      if (modal.classList.contains('open')) close();
    });
  })();
</script>
