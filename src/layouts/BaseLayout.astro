---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Sidebar from '../components/Sidebar.astro';
import SplashScreen from '../components/SplashScreen.astro';
import SearchModal from '../components/SearchModal.astro';
import MouseTrail from '../components/MouseTrail.astro';
import { SITE } from '../consts';
import fs from 'node:fs';

// 背景图随机池 — 往 src/assets/bg/ 丢图即可自动加入
const bgPool = Object.values(
  import.meta.glob<{ default: import('astro').ImageMetadata }>('../assets/bg/*.{webp,jpg,png}', { eager: true })
).map(m => m.default.src);

// Keystatic 后台自定义背景图（从 index.yaml 读取）
try {
  const raw = fs.readFileSync('src/content/site/index.yaml', 'utf-8');
  const lines = raw.split('\n');
  let inArray = false;
  for (const line of lines) {
    if (line.trim() === 'backgroundImages:') { inArray = true; continue; }
    if (inArray && line.trimStart().startsWith('- ')) {
      const url = line.trimStart().slice(2).trim();
      if (url) bgPool.push(url);
    } else if (inArray && !line.trimStart().startsWith('- ')) {
      break; // array ended
    }
  }
} catch (_) { /* 还没有站点设置文件 */ }

interface Props {
  title: string;
  description?: string;
  hideSidebar?: boolean;
  showToc?: boolean;
}

const { title, description, hideSidebar, showToc } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description || SITE.description} />
    <meta name="theme-color" content="#f5f2ed" />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;700&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />
    <title>{title} | {SITE.title}</title>
    <meta name="astro-view-transitions-enabled" content="true" />

    <!-- 页面加载计数（必须在 body 内嵌脚本之前运行） -->
    <script is:inline>
      window.__pageLoads = (window.__pageLoads || 0) + 1;
      window.__isHardReload = window.__pageLoads === 1;
    </script>

    <!-- 随机背景图：每次刷新换一张 -->
    <script type="application/json" id="bg-pool" set:html={JSON.stringify(bgPool)}></script>
    <script is:inline>
      (function() {
        var pool = JSON.parse(document.getElementById('bg-pool').textContent);
        if (pool.length > 0) {
          document.documentElement.style.setProperty(
            '--blog-bg-image',
            'url(' + pool[Math.floor(Math.random() * pool.length)] + ')'
          );
        }
      })();
    </script>
  </head>
  <body>
    <SplashScreen />
    <SearchModal />
    <MouseTrail />
    <Header />

    <!-- 主内容区 -->
    <div class="flex-1 pt-[var(--blog-header-h)] flex" transition:animate="slide">
      <div class="mx-auto w-full px-4 md:px-8 flex gap-4 py-8" style="max-width: 1500px;">
        {showToc && (
          <aside class="hidden lg:block shrink-0 self-start sticky overflow-y-auto" style="min-width: 180px; width: 200px; top: calc(var(--blog-header-h) + 24px); max-height: calc(100vh - var(--blog-header-h) - 48px);">
            <div style="background: var(--blog-surface); border: 1px solid var(--blog-border); border-radius: var(--blog-radius-lg); padding: 0.875rem 0.75rem;" data-pagefind-ignore>
              <h3 class="text-xs font-semibold mb-3 tracking-wider" style="color: var(--blog-text-tertiary);">📖 目录</h3>
              <nav id="article-toc" class="toc-tree"></nav>
            </div>
            <style>
              .toc-tree {
                position: relative;
                padding-left: 18px;
              }
              .toc-tree::before {
                content: '';
                position: absolute;
                left: 6px;
                top: 5px;
                bottom: 5px;
                width: 1.5px;
                background: var(--blog-text-tertiary);
                border-radius: 1px;
              }
              .toc-item {
                display: flex;
                align-items: flex-start;
                gap: 6px;
                padding: 3px 0;
                position: relative;
                cursor: pointer;
              }
              .toc-item a {
                color: var(--blog-text-secondary);
                text-decoration: none;
                font-size: 0.8125rem;
                line-height: 1.5;
                transition: color 0.15s;
                word-break: break-word;
              }
              .toc-item a:hover {
                color: var(--blog-accent);
              }
              .toc-item.active a {
                color: var(--blog-accent);
                font-weight: 500;
              }
              .toc-dot {
                flex-shrink: 0;
                border-radius: 50%;
                background: var(--blog-text-tertiary);
                margin-top: 5px;
                position: relative;
                z-index: 1;
                transition: background 0.15s, box-shadow 0.15s;
              }
              .toc-item-h2 .toc-dot {
                width: 7px;
                height: 7px;
                margin-left: -2px;
              }
              .toc-item-h3 .toc-dot {
                width: 5px;
                height: 5px;
                margin-left: -1px;
              }
              .toc-item-h3 {
                padding-left: 6px;
              }
              .toc-item-h3::before {
                content: '';
                position: absolute;
                left: -12px;
                top: 50%;
                width: 10px;
                height: 1.5px;
                background: var(--blog-text-tertiary);
              }
              .toc-item.active .toc-dot {
                background: var(--blog-accent);
                box-shadow: 0 0 0 3px var(--blog-accent-light);
              }
            </style>
            <script is:inline>
              (function() {
                function buildTOC() {
                  const article = document.querySelector('[itemprop="articleBody"]');
                  const toc = document.getElementById('article-toc');
                  if (!article || !toc) return;

                  const headings = article.querySelectorAll('h2, h3');
                  if (headings.length === 0) {
                    toc.parentElement.style.display = 'none';
                    return;
                  }

                  headings.forEach((h, i) => {
                    const id = 'toc-' + i;
                    h.id = id;

                    const item = document.createElement('div');
                    item.className = 'toc-item ' + (h.tagName === 'H3' ? 'toc-item-h3' : 'toc-item-h2');

                    const dot = document.createElement('span');
                    dot.className = 'toc-dot';
                    item.appendChild(dot);

                    const a = document.createElement('a');
                    a.href = '#' + id;
                    a.textContent = h.textContent;
                    item.appendChild(a);

                    a.addEventListener('click', (e) => {
                      e.preventDefault();
                      h.scrollIntoView({ behavior: 'smooth', block: 'start' });
                      history.pushState(null, '', '#' + id);
                    });

                    toc.appendChild(item);
                  });

                  const items = toc.querySelectorAll('.toc-item');
                  function onScroll() {
                    let current = -1;
                    headings.forEach((h, i) => {
                      const rect = h.getBoundingClientRect();
                      if (rect.top <= 130) current = i;
                    });
                    items.forEach((item, i) => {
                      item.classList.toggle('active', i === current);
                    });
                  }
                  window.addEventListener('scroll', onScroll, { passive: true });
                  onScroll();
                }

                if (document.readyState === 'loading') {
                  document.addEventListener('DOMContentLoaded', buildTOC);
                } else {
                  buildTOC();
                }
                document.addEventListener('astro:page-load', buildTOC);
              })();
            </script>
          </aside>
        )}

        <main class="flex-1 min-w-0">
          <slot />
        </main>

        {!hideSidebar && !showToc && (
          <aside class="hidden lg:block shrink-0 self-start sticky overflow-y-auto" style="width: var(--blog-sidebar-w); top: calc(var(--blog-header-h) + 24px); max-height: calc(100vh - var(--blog-header-h) - 48px);">
            <Sidebar />
          </aside>
        )}
      </div>
    </div>

    <Footer />

    <!-- 不蒜子统计 -->
    <script is:inline defer src="https://busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js"></script>

    <!-- 主题 -->
    <script is:inline>
      (function() {
        if (localStorage.getItem('blog-theme') === 'dark') {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <!-- View Transitions 开屏拦截 -->
    <script>
      window.__splashBlocked = false;
      document.addEventListener('astro:before-preparation', function() {
        window.__splashBlocked = true;
        sessionStorage.setItem('splash_blocked', '1');
      });
    </script>
  </body>
</html>
