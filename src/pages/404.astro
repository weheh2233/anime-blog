---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404" description="页面未找到" hideSidebar>
  <div class="max-w-3xl mx-auto text-center py-24">
    <div class="text-8xl mb-6" style="color: var(--blog-accent);">404</div>
    <h1 class="text-2xl font-bold mb-4" style="color: var(--blog-text-primary);">页面不见了</h1>
    <p class="mb-8" style="color: var(--blog-text-secondary);">
      你访问的页面不存在，可能已被移除了。
    </p>
    <div class="flex gap-4 justify-center">
      <a
        href="/"
        class="px-6 py-3 rounded-[var(--blog-radius-sm)] font-medium no-underline transition-all"
        style="background: var(--blog-accent); color: white;"
      >
        ← 回到首页
      </a>
      <a
        href="/blog"
        class="px-6 py-3 rounded-[var(--blog-radius-sm)] font-medium no-underline transition-colors"
        style="border: 1px solid var(--blog-border); color: var(--blog-text-secondary);"
      >
        浏览博客
      </a>
    </div>
  </div>
</BaseLayout>
